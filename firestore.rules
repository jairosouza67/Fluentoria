rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if user is admin
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: Check if user is accessing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Admin emails - only admins can manage
    match /adminEmails/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Courses - anyone authenticated can read, only admins write
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Mindful Flow - same pattern
    match /mindful_flow/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Music - same pattern
    match /music/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Student completions
    match /student_completions/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Gamification and Activities
    match /student_progress/{userId} {
      allow read, write: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    match /student_activities/{activityId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.studentId) || isAdmin());
      allow create: if isAuthenticated() && (isOwner(request.resource.data.studentId) || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /achievements/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
